# Observability in a Box - Environment Variables
# =============================================
#
# SETUP: Copy this file to .env and customize:
#   cp .env.example .env
#
# ⚠️  IMPORTANT: Change GRAFANA_ADMIN_PASSWORD before running!
#
# All values shown are defaults - uncomment and modify to customize

# ==================== Grafana ====================
# Dashboard credentials (required)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD  # <-- Change this!

# Bind address for browser-facing endpoints (safe default: loopback only)
# Set BIND_ADDR=0.0.0.0 only when you intentionally expose Grafana on a LAN.
# BIND_ADDR=127.0.0.1

# Web UI port (default: 3000)
# GRAFANA_PORT=3000

# ==================== Logging Stack ====================
# Loki log storage API port (localhost only)
# LOKI_PORT=3100

# Alloy logging pipeline UI port
# ALLOY_LOGGING_PORT=12345

# ==================== Metrics Stack ====================
# Prometheus query API port (localhost only)
# PROMETHEUS_PORT=9090

# Alloy metrics collection UI port (localhost only)
# ALLOY_METRICS_PORT=12347

# cAdvisor for container metrics (localhost only)
# CADVISOR_PORT=8080

# Blackbox Exporter for endpoint probing (localhost only)
# BLACKBOX_PORT=9115

# Prometheus data retention
# Format: Xd (days), Xh (hours), Xw (weeks)
# PROMETHEUS_RETENTION_TIME=15d

# Maximum disk space for metrics (uses oldest-first eviction)
# Format: XGB, XMB, XKB
# PROMETHEUS_RETENTION_SIZE=5GB

# ==================== Telemetry Stack ====================
# Tempo trace storage API ports (localhost only)
# TEMPO_HTTP_PORT=3200
# TEMPO_GRPC_PORT=9095

# OpenTelemetry receiver ports (safe default: loopback only)
# Set OTEL_BIND_ADDR=0.0.0.0 when external apps should send traces over the LAN.
# OTEL_BIND_ADDR=127.0.0.1
# OTEL_GRPC_PORT=4317
# OTEL_HTTP_PORT=4318

# Alloy telemetry pipeline UI port
# ALLOY_TELEMETRY_PORT=12346

# ==================== Profiling Stack (Optional) ====================
# Install with: make install-profiling
#
# Pyroscope continuous profiling port (localhost only)
# PYROSCOPE_PORT=4040

# ==================== Image Versions ====================
# Override to use different versions (default: pinned stable versions)
# Set to 'latest' for bleeding edge, or specific version tags
#
# GRAFANA_VERSION=12.3.2
# LOKI_VERSION=3.6.5
# ALLOY_VERSION=v1.13.0
# PROMETHEUS_VERSION=v3.9.1
# CADVISOR_VERSION=v0.52.1
# BLACKBOX_VERSION=v0.28.0
# TEMPO_VERSION=2.10.0
# PYROSCOPE_VERSION=1.18.0
#
# Optional services (when enabled via profile)
# PUSHGATEWAY_VERSION=v1.6.2
#
# Quick tip: Run 'make latest' to use :latest tags for all images

# ==================== Shared Services (Optional) ====================
# Install with: make install-services
#
# PostgreSQL
# POSTGRES_USER=oib
# POSTGRES_PASSWORD=oib_secret
# POSTGRES_DB=oib_demo
# POSTGRES_PORT=5432
#
# Redis
# REDIS_PORT=6379

# Demo/example app bind address (safe default: loopback only)
# DEMO_BIND_ADDR=127.0.0.1

# ==================== Advanced ====================
# Timezone for log timestamps (default: UTC)
# TZ=UTC

# ==================== Data Retention (Config File Only) ====================
# NOTE: Loki and Tempo retention are configured in their respective config files:
# - Loki: logging/config/loki-config.yml (retention_period: 168h = 7 days)
# - Tempo: telemetry/config/tempo.yaml (block_retention: 72h = 3 days)
# These cannot be set via environment variables.
